# ============================================
# Dr. Venom Trader - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.

# --- General ---
COMPOSE_PROJECT_NAME=drvenomtrader
NODE_ENV=production

# --- PostgreSQL ---
POSTGRES_USER=venom
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=drvenomtrader
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
DEBUG=false
LOG_LEVEL=info

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws

# --- Exchange APIs ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- CoinGlass API (Liquidation Data) ---
COINGLASS_API_KEY=

# --- Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# --- Nginx ---
DOMAIN=localhost
